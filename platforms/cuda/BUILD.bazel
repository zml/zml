load("@rules_cc//cc:cc_library.bzl", "cc_library")
load("@rules_zig//zig:defs.bzl", "zig_library", "zig_shared_library", "zig_binary");

zig_binary(
    name = "compat_probe",
    main = "compat_probe.zig",
    visibility = ["@libpjrt_cuda//:__subpackages__"],
)

zig_shared_library(
    name = "zmlxcuda",
    main = "zmlxcuda.zig",
    shared_lib_name = "libzmlxcuda.so.0",
    visibility = ["@libpjrt_cuda//:__subpackages__"],
    # Use Clang's compiler-rt, but disable stack checking
    # to avoid requiring on the _zig_probe_stack symbol.
    zigopts = ["-fno-stack-check"],
    deps = ["//stdx"],
)

cc_library(
    name = "empty",
    tags = ["manual"],
    defines = ["ZML_RUNTIME_CUDA_DISABLED"],
)

cc_library(
    name = "libpjrt_cuda",
    tags = ["manual"],
    hdrs = ["libpjrt_cuda.h"],
    defines = ["ZML_RUNTIME_CUDA"],
    deps = ["@libpjrt_cuda"],
)

zig_library(
    name = "cuda",
    tags = ["manual"],
    data = select({
        "//platforms:cuda.enabled": [
            "@flashattn//:libflashattn",
            "@cuda_nvtx//:cuda_nvtx",
        ],
        "//conditions:default": [":empty"],
    }),
    srcs = ["compat_probe.zig"],
    import_name = "platforms/cuda",
    main = "cuda.zig",
    visibility = ["//visibility:public"],
    deps = [
        "//pjrt",
    ] + select({
        "//platforms:cuda.enabled": [
            ":libpjrt_cuda",
            "//bazel",
            "//stdx",
            "@rules_zig//zig/runfiles",
        ],
        "//conditions:default": [":empty"],
    }),
)

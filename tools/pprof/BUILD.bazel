sh_binary(
    name = "pprof",
    srcs = ["pprof.sh"],
    args = [
        "--bootstrap-rlocation=$(rlocationpath //tools/profile:bootstrap.sh)",
        "--source-license-rlocation=$(rlocationpath @pprof//:LICENSE)",
    ],
    data = [
        "@bazel_tools//tools/bash/runfiles:runfiles",
        "@pprof//:LICENSE",
        "@pprof//:source_tree",
        "//tools/profile:bootstrap.sh",
    ],
    tags = ["manual"],
    visibility = ["//visibility:public"],
)

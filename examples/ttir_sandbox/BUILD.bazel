load("@aspect_bazel_lib//lib:copy_to_directory.bzl", "copy_to_directory")
load("@python_versions//3.12:defs.bzl", py_binary = "py_binary")
load("@rules_cc//cc:cc_library.bzl", "cc_library")
load("@rules_python//python/uv:lock.bzl", uv_lock = "lock")
load("@rules_zig//zig:defs.bzl", "zig_binary", "zig_library")
load("@zml//bazel:runfiles.bzl", "runfiles_to_default")

uv_lock(
    name = "requirements",
    srcs = ["requirements.in"],
    out = "requirements.lock.txt",
    args = [
        "--emit-index-url",
        "--index-strategy=unsafe-best-match",
        "--upgrade",
        "--universal",
    ],
    python_version = "3.12",
    tags = ["manual"],
)

py_binary(
    name = "ttir_compile",
    srcs = [
        "ttir_compile.py",
    ] + glob([
        "wrapped_kernels/*.py",
        "vllm_kernels/*.py",
    ]),
    deps = [
        "@ttir_sandbox_py_deps//torch",
        "@ttir_sandbox_py_deps//torchaudio",
        "@ttir_sandbox_py_deps//torchvision",
        "@ttir_sandbox_py_deps//triton",
    ],
)

runfiles_to_default(
    name = "ttir_compile_files",
    deps = [":ttir_compile"],
)

cc_library(
    name = "libpython",
    hdrs = ["libpython.h"],
    deps = [
        "@rules_python//python/cc:current_py_cc_headers",
        "@rules_python//python/cc:current_py_cc_libs",
    ],
)

zig_library(
    name = "ttir_compile_sandbox",
    main = "ttir_compile_sandbox.zig",
    data = [":ttir_compile_files"],
    deps = [
        "//zml",
        ":libpython",
        "@rules_zig//zig/runfiles",
    ],
)

zig_binary(
    name = "ttir_compile_sandbox_smoke",
    main = "e2e_tests/ttir_compile_sandbox_smoke.zig",
    data = [":ttir_compile_files"],
    deps = [
        ":ttir_compile_sandbox",
    ],
)

zig_binary(
    name = "hello_world_e2e",
    main = "e2e_tests/hello_world.zig",
    data = [":ttir_compile_files"],
    deps = [
        "//zml",
        ":ttir_compile_sandbox",
    ],
)

zig_binary(
    name = "2d_unified_attention_e2e",
    main = "e2e_tests/2d_unified_attention.zig",
    data = [":ttir_compile_files"],
    deps = [
        "//zml",
        ":ttir_compile_sandbox",
    ],
)

zig_binary(
    name = "3d_unified_attention_e2e",
    main = "e2e_tests/3d_unified_attention.zig",
    data = [":ttir_compile_files"],
    deps = [
        "//zml",
        ":ttir_compile_sandbox",
    ],
)

zig_binary(
    name = "decode_attention_e2e",
    main = "e2e_tests/decode_attention.zig",
    data = [":ttir_compile_files"],
    deps = [
        "//zml",
        ":ttir_compile_sandbox",
    ],
)

zig_binary(
    name = "prefill_attention_e2e",
    main = "e2e_tests/prefill_attention.zig",
    data = [":ttir_compile_files"],
    deps = [
        "//zml",
        ":ttir_compile_sandbox",
    ],
)

copy_to_directory(
    name = "sandbox",
    srcs = [
        ":ttir_compile_sandbox",
        ":ttir_compile",
        ":ttir_compile_files",
    ],
    replace_prefixes = {
        "ttir_compile_sandbox": "bin/ttir_compile_sandbox",
        "ttir_compile.py": "site-packages/ttir_compile.py",
    },
    exclude_srcs_patterns = [
        "**/tests/**",
        "**/_solib_*/**",
    ],
    include_srcs_patterns = [
        "**ttir_compile**",
        "ttir_compile_sandbox",
        "wrapped_kernels/**",
        "vllm_kernels/**",
        "**/lib**",
        "lib/python*/**",
        "site-packages/**",
    ],
    allow_overwrites = True,
    add_directory_to_runfiles = False,
    include_external_repositories = ["**"],
    hardlink = "on",
)

load("@rules_zig//zig:defs.bzl", "zig_binary", "zig_library", "zig_test")

zig_library(
    name = "tokenizer",
    srcs = ["homemade.zig"],
    import_name = "zml/tokenizer",
    main = "tokenizer.zig",
    tags = ["manual"],
    visibility = ["//visibility:public"],
    deps = [
        "//ffi:zig",
        "//stdx",
        "//zml/tokenizer/iree",
        "//zml/tokenizer/sentencepiece",
    ],
)

zig_binary(
    name = "main",
    main = "main.zig",
    visibility = ["//visibility:public"],
    deps = [
        ":tokenizer",
        "//stdx",
    ],
)

zig_test(
    name = "test",
    deps = [
        ":tokenizer",
    ],
)


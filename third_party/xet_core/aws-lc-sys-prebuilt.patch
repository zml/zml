+fn write_unprefixed_pregenerated_bindings(manifest_dir: &Path, out_dir: &Path) {
+    let (source_file, prefixed, unprefixed) = if target_has_prefixed_symbols() {
+        (
+            "universal_prefixed_crypto.rs",
+            format!("\\u{{1}}_{}_", prefix_string()),
+            "\\u{1}_".to_string(),
+        )
+    } else {
+        (
+            "universal_crypto.rs",
+            format!("\\u{{1}}{}_", prefix_string()),
+            "\\u{1}".to_string(),
+        )
+    };
+    let source_path = manifest_dir.join("src").join(source_file);
+    let bindings = std::fs::read_to_string(&source_path)
+        .unwrap_or_else(|err| panic!("Failed to read {}: {err}", source_path.display()))
+        .replace("#![allow(", "#[allow(")
+        .replace(&prefixed, &unprefixed);
+    let generated_path = out_dir.join("bindings.rs");
+    std::fs::write(&generated_path, bindings)
+        .unwrap_or_else(|err| panic!("Failed to write {}: {err}", generated_path.display()));
+    emit_rustc_cfg("use_bindgen_pregenerated");
+}

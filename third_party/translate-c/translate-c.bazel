load("@rules_zig//zig:defs.bzl", "zig_binary", "zig_library")

zig_library(
    name = "c_builtins",
    main = "lib/c_builtins.zig",
)

zig_library(
    name = "helpers",
    main = "lib/helpers.zig",
)

zig_binary(
    name = "translate-c",
    data = glob(["lib/**/*.zig"]),
    srcs = glob(["src/**/*.zig"]),
    main = "src/main.zig",
    linkopts = ["-lc"],
    deps = [
        ":c_builtins",
        ":helpers",
        "@arocc//:aro",
    ],
    visibility = ["//visibility:public"],
)

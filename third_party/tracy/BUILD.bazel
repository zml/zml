load("@rules_cc//cc:cc_library.bzl", "cc_library")

cc_library(
    name = "tracy_shim",
    srcs = ["tracy_shim.cc"],
    hdrs = ["tracy_shim.h"],
    copts = [
        "-std=c++20",
        "-DTRACY_ENABLE",
    ],
    deps = ["@tracy_public_upstream//:client"],
    visibility = ["//visibility:private"],
)

cc_library(
    name = "tracy_internal",
    deps = [
        ":tracy_shim",
        "@tracy_public_upstream//:client",
    ],
    visibility = ["//visibility:private"],
)

cc_library(
    name = "tracy",
    implementation_deps = [":tracy_internal"],
    visibility = ["//visibility:public"],
)
